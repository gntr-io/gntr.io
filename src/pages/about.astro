---
import MainLayout from "../layouts/MainLayout.astro";

const values = [
  {
    title: "Domain first",
    description:
      "We start with your expertise, not the technology. The best AI systems are built around how you actually think and work.",
  },
  {
    title: "No bloat",
    description:
      "We build exactly what you need. No unnecessary features, no over-engineered abstractions — just systems that do their job well.",
  },
  {
    title: "Honest timelines",
    description:
      "Clear communication from day one. We tell you what we can build, what it will cost, and when it will be done.",
  },
  {
    title: "Built to hand over",
    description:
      "Everything we build is yours. Clean code, clear documentation, and no artificial lock-in to us.",
  },
];
---

<MainLayout
  title="About - gntr"
  description="gntr is a custom AI development agency. We build systems that encode your expertise, connect your data, and automate what your team shouldn't have to do manually."
>
  <section class="about">
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">
          <span class="prompt">›</span> About gntr
        </h1>
      </div>

      <div class="about-content">
        <div class="intro-section">
          <div class="terminal-box">
            <p class="terminal-line">
              <span class="prompt">›</span>
              <span class="command">gntr --version</span>
            </p>
            <p class="terminal-output">v9.1.0 - Custom AI systems for people who know their domain</p>
          </div>

          <div class="intro-text">
            <h2 class="section-heading">Who We Are</h2>
            <p>
              gntr is a custom AI development agency. We build systems that encode what you know and scale what you do — for your team, or as a product you can sell.
            </p>
            <p>
              We work with businesses that have real expertise and outgrown generic software. Our job is to take what's in your head — your frameworks, your instincts, your process — and engineer it into something that runs without you.
            </p>
          </div>
        </div>

        <div class="values-section">
          <h2 class="section-heading">
            <span class="prompt">›</span> Our Values
          </h2>
          <div class="values-grid">
            {
              values.map((value) => (
                <div class="value-card">
                  <h3 class="value-title">{value.title}</h3>
                  <p class="value-description">{value.description}</p>
                </div>
              ))
            }
          </div>
        </div>

        <div class="services-detail">
          <h2 class="section-heading">
            <span class="prompt">›</span> What We Do
          </h2>
          <div class="services-list">
            <div class="service-item">
              <code class="service-command">$ gntr build --type=internal-tool</code>
              <h3 class="service-name">Internal AI Tools</h3>
              <p class="service-desc">
                We build AI that handles the repeatable parts of your team's work, so your people focus on what actually needs a human.
              </p>
            </div>

            <div class="service-item">
              <code class="service-command">$ gntr build --type=data-pipeline</code>
              <h3 class="service-name">Data & Insight Systems</h3>
              <p class="service-desc">
                We connect your scattered data, keep it fresh, and layer in AI that tells you what it means — without a data analyst on payroll.
              </p>
            </div>

            <div class="service-item">
              <code class="service-command">$ gntr build --type=saas-product</code>
              <h3 class="service-name">Productised Expertise</h3>
              <p class="service-desc">
                You've built a methodology clients pay for. We encode it into a system you can sell, license, or use as a differentiator.
              </p>
            </div>

            <div class="service-item">
              <code class="service-command">$ gntr build --type=website</code>
              <h3 class="service-name">AI-Integrated Websites</h3>
              <p class="service-desc">
                Custom websites with AI built in — not bolted on. Intelligent forms, dynamic content, and automation from day one.
              </p>
            </div>

            <div class="service-item">
              <code class="service-command">$ gntr build --type=mobile</code>
              <h3 class="service-name">Mobile Applications</h3>
              <p class="service-desc">
                iOS and Android apps with AI integrations baked into the experience, built for performance and scale.
              </p>
            </div>

            <div class="service-item">
              <code class="service-command">$ gntr build --type=discovery</code>
              <h3 class="service-name">Discovery & Consulting</h3>
              <p class="service-desc">
                Not ready to build? We spend 2–4 weeks inside your business, then give you a concrete plan — no obligation to build with us.
              </p>
            </div>
          </div>
        </div>

        <div class="cta-section">
          <div class="terminal-box">
            <p class="terminal-line">
              <span class="prompt">›</span>
              <span class="command">gntr connect</span>
            </p>
            <p class="cta-text">Ready to work together?</p>
            <a href="/contact" class="btn btn-primary">Get In Touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style lang="scss">
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .about {
    margin-bottom: 4rem;
  }

  .page-header {
    margin-bottom: 3rem;

    @include tablet {
      margin-bottom: 4rem;
    }
  }

  .page-title {
    font-size: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;

    @include tablet {
      font-size: 2.5rem;
    }
  }

  .prompt {
    color: $cta-primary;
    font-weight: 600;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .intro-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;

    @include tablet {
      gap: 3rem;
    }
  }

  .terminal-box {
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    padding: 1.5rem;
    border-radius: 4px;
  }

  .terminal-line {
    font-family: "Courier New", monospace;
    color: $text-body;
    margin-bottom: 0.5rem;
  }

  .command {
    color: $cta-hover;
    margin-left: 0.5rem;
  }

  .terminal-output {
    font-family: "Courier New", monospace;
    color: $text-body;
    opacity: 0.8;
  }

  .intro-text {
    h2 {
      margin-bottom: 1.5rem;
    }

    p {
      color: $text-body;
      line-height: 1.7;
      font-size: 1.05rem;
      margin-bottom: 1rem;
      max-width: 720px;
    }
  }

  .section-heading {
    font-size: 1.75rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;

    @include tablet {
      font-size: 2rem;
    }
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;

    @include tablet {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .value-card {
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    padding: 1.5rem;
    border-radius: 4px;
    transition: all 0.3s ease;

    &:hover {
      border-color: $cta-primary;
      transform: translateY(-2px);
    }
  }

  .value-title {
    font-size: 1.25rem;
    color: $text-heading;
    margin-bottom: 0.75rem;
  }

  .value-description {
    color: $text-body;
    line-height: 1.6;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .service-item {
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    padding: 1.5rem;
    border-radius: 4px;
    transition: all 0.3s ease;

    &:hover {
      border-color: $cta-primary;
    }
  }

  .service-command {
    font-family: "Courier New", monospace;
    font-size: 0.875rem;
    color: $cta-hover;
    background-color: rgba($bg-code, 0.5);
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .service-name {
    font-size: 1.375rem;
    color: $text-heading;
    margin-bottom: 0.75rem;
  }

  .service-desc {
    color: $text-body;
    line-height: 1.6;
  }

  .cta-section {
    text-align: center;

    .terminal-box {
      padding: 2rem 1.5rem;

      @include tablet {
        padding: 3rem 2rem;
      }
    }
  }

  .cta-text {
    font-size: 1.25rem;
    color: $text-heading;
    margin: 1rem 0 1.5rem;
    font-weight: 600;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    border-radius: 4px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 1rem;
    min-height: 44px;
  }

  .btn-primary {
    background-color: $cta-primary;
    color: $bg-primary;
    border-color: $cta-primary;

    &:hover {
      background-color: $cta-hover;
      border-color: $cta-hover;
      transform: translateY(-1px);
    }
  }
</style>
