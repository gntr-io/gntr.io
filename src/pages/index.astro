---
import MainLayout from "../layouts/MainLayout.astro";

const services = [
  {
    title: "Internal AI Tools",
    description: "We build AI that handles the repeatable parts of your team's work, so your people focus on what actually needs a human.",
    command: "$ gntr build --type=internal-tool",
  },
  {
    title: "Data & Insight Systems",
    description: "We connect your scattered data, keep it fresh, and layer in AI that tells you what it means — without a data analyst on payroll.",
    command: "$ gntr build --type=data-pipeline",
  },
  {
    title: "Productised Expertise",
    description: "You've built a methodology clients pay for. We encode it into a system you can sell, license, or use as a differentiator.",
    command: "$ gntr build --type=saas-product",
  },
  {
    title: "AI-Integrated Websites",
    description: "Custom websites with AI built in — not bolted on. Intelligent forms, dynamic content, and automation from day one.",
    command: "$ gntr build --type=website",
  },
  {
    title: "Mobile Applications",
    description: "iOS and Android apps with AI integrations baked into the experience, built for performance and scale.",
    command: "$ gntr build --type=mobile",
  },
  {
    title: "Discovery & Consulting",
    description: "Not ready to build? We spend 2–4 weeks inside your business, then give you a concrete plan — no obligation to build with us.",
    command: "$ gntr build --type=discovery",
  },
];
---

<MainLayout
  title="gntr - Custom AI Development"
  description="gntr is a custom AI development agency. We build systems that encode your expertise, connect your data, and automate what your team shouldn't have to do manually."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="terminal-window">
        <div class="terminal-header">
          <span class="terminal-title">gntr@terminal:~</span>
        </div>
        <div class="terminal-body">
          <p class="terminal-line">
            <span class="prompt">›</span>
            <span class="command">gntr build --type=ai-system</span>
          </p>
          <p class="terminal-output">
            Building AI systems for people who know their domain.
          </p>
          <h1 class="hero-title">
            Your expertise. <span class="highlight">Engineered.</span>
          </h1>
          <p class="hero-description">
            We build custom AI systems that encode what you know and scale what you do — for your team, or as a product you can sell.
          </p>
          <div class="hero-actions">
            <a href="/contact" class="btn btn-primary" id="hero-get-started">Start with a conversation</a>
            <a href="/portfolio" class="btn btn-secondary" id="hero-view-work">See our work</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services">
    <div class="container">
      <h2 class="section-title">
        <span class="prompt">›</span> Services
      </h2>
      <div class="services-grid">
        {
          services.map((service) => (
            <div class="service-card">
              <div class="card-header">
                <code class="command-text">{service.command}</code>
              </div>
              <h3 class="card-title">{service.title}</h3>
              <p class="card-description">{service.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact" id="contact">
    <div class="container">
      <h2 class="section-title">
        <span class="prompt">›</span> Contact
      </h2>
      <div class="contact-wrapper">
        <form class="contact-form" id="homeContactForm">
          <input
            type="hidden"
            name="access_key"
            value={import.meta.env.PUBLIC_WEB3FORMS_KEY || ""}
          />
          <input type="hidden" name="subject" value="New Contact from GNTR Website - Home" />
          <input type="hidden" name="from_name" value="GNTR Website" />
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

          <div class="form-group">
            <label for="email" class="form-label">
              <span class="prompt">›</span> Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="you@example.com"
              required
            />
          </div>
          <div class="form-group">
            <label for="message" class="form-label">
              <span class="prompt">›</span> Message
            </label>
            <textarea
              id="message"
              name="message"
              class="form-input"
              rows="6"
              placeholder="Tell us about your project..."
              required
            />
          </div>
          <button type="submit" class="btn btn-primary btn-block">
            Send Message
          </button>
          <p class="form-status" id="homeFormStatus"></p>
        </form>
      </div>
    </div>
  </section>
</MainLayout>

<style lang="scss">
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .hero {
    margin-bottom: 4rem;

    @include tablet {
      margin-bottom: 6rem;
    }
  }

  .terminal-window {
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    border-radius: 8px;
    overflow: hidden;
  }

  .terminal-header {
    background-color: rgba($bg-primary, 0.5);
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba($cta-primary, 0.2);
  }

  .terminal-title {
    font-family: "Courier New", monospace;
    font-size: 0.875rem;
    color: $text-body;
  }

  .terminal-body {
    padding: 2rem 1rem;

    @include tablet {
      padding: 3rem 2rem;
    }
  }

  .terminal-line {
    font-family: "Courier New", monospace;
    color: $text-body;
    margin-bottom: 0.5rem;
  }

  .prompt {
    color: $cta-primary;
    margin-right: 0.5rem;
    font-weight: 600;
  }

  .command {
    color: $cta-hover;
  }

  .terminal-output {
    font-family: "Courier New", monospace;
    color: $text-body;
    margin-bottom: 2rem;
    opacity: 0.8;
  }

  .hero-title {
    font-size: 2rem;
    line-height: 1.2;
    margin-bottom: 1rem;

    @include tablet {
      font-size: 3rem;
    }

    .highlight {
      color: $cta-primary;
    }
  }

  .hero-description {
    font-size: 1.125rem;
    color: $text-body;
    margin-bottom: 2rem;
    max-width: 600px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .services {
    margin-bottom: 4rem;

    @include tablet {
      margin-bottom: 6rem;
    }
  }

  .section-title {
    font-size: 1.75rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;

    @include tablet {
      font-size: 2.25rem;
    }
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;

    @include tablet {
      grid-template-columns: repeat(2, 1fr);
    }

    @include desktop {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    padding: 1.5rem;
    border-radius: 8px;
    transition: all 0.3s ease;

    &:hover {
      border-color: $cta-primary;
      transform: translateY(-2px);
    }
  }

  .card-header {
    margin-bottom: 1rem;
  }

  .command-text {
    font-family: "Courier New", monospace;
    font-size: 0.875rem;
    color: $cta-hover;
    background-color: rgba($bg-code, 0.5);
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    display: inline-block;
  }

  .card-title {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: $text-heading;
  }

  .card-description {
    color: $text-body;
    line-height: 1.6;
  }

  .contact {
    margin-bottom: 4rem;

    @include tablet {
      margin-bottom: 6rem;
    }
  }

  .contact-wrapper {
    max-width: 600px;
  }

  .contact-form {
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    padding: 2rem 1rem;
    border-radius: 8px;

    @include tablet {
      padding: 2.5rem 2rem;
    }
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: $text-heading;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .form-input {
    width: 100%;
    background-color: rgba($bg-primary, 0.5);
    border: 1px solid rgba($cta-primary, 0.2);
    color: $text-body;
    padding: 0.75rem;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.3s ease;

    &:focus {
      outline: none;
      border-color: $cta-primary;
      background-color: rgba($bg-primary, 0.7);
    }

    &::placeholder {
      color: rgba($text-body, 0.5);
    }

    &[type="email"],
    &[type="text"] {
      font-family: "Courier New", monospace;
    }
  }

  textarea.form-input {
    resize: vertical;
    min-height: 120px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 1rem;
    min-height: 44px;
  }

  .btn-primary {
    background-color: $cta-primary;
    color: $bg-primary;
    border-color: $cta-primary;

    &:hover {
      background-color: $cta-hover;
      border-color: $cta-hover;
      transform: translateY(-1px);
    }
  }

  .btn-secondary {
    background-color: transparent;
    color: $text-heading;
    border-color: rgba($cta-primary, 0.4);

    &:hover {
      border-color: $cta-primary;
      background-color: rgba($cta-primary, 0.1);
    }
  }

  .btn-block {
    width: 100%;
  }

  .form-status {
    margin-top: 1rem;
    padding: 0.75rem;
    border-radius: 8px;
    text-align: center;
    font-weight: 500;
    min-height: 1rem;
  }

  .hidden {
    display: none !important;
  }
</style>

<script>
  import { initContactForm } from "../utils/formSubmit";

  document.addEventListener("DOMContentLoaded", () => {
    const getStartedBtn = document.getElementById("hero-get-started");
    const viewWorkBtn = document.getElementById("hero-view-work");

    if (getStartedBtn) {
      getStartedBtn.addEventListener("click", () => {
        window.posthog?.capture("hero_get_started_clicked", {
          location: "hero_section",
          button_text: "Start with a conversation",
        });
      });
    }

    if (viewWorkBtn) {
      viewWorkBtn.addEventListener("click", () => {
        window.posthog?.capture("hero_view_work_clicked", {
          location: "hero_section",
          button_text: "View Work",
        });
      });
    }

    initContactForm({
      formId: "homeContactForm",
      statusId: "homeFormStatus",
      posthogEvent: "contact_form_submitted",
      posthogProps: () => ({ form: "home" }),
    });
  });
</script>
