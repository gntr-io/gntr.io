---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<MainLayout
  title={`${post.data.title} - GNTR Blog`}
  description={post.data.description}
  type="article"
>
  <article class="blog-post">
    <div class="container">
      <div class="post-header">
        <a href="/blog" class="back-link">
          <span>←</span> Back to Blog
        </a>
        <div class="post-meta">
          <code class="category-tag">{post.data.category}</code>
          <span class="post-date">{formatDate(post.data.date)}</span>
          <span class="read-time">{post.data.readTime} read</span>
        </div>
        <h1 class="post-title">
          <span class="prompt">›</span> {post.data.title}
        </h1>
        <p class="post-description">{post.data.description}</p>
      </div>

      <div class="post-content">
        <div class="content-wrapper"><Content /></div>
      </div>

      <div class="post-footer">
        <div class="terminal-box">
          <p class="terminal-text">
            <span class="prompt">›</span>
            <span class="command">gntr blog --read-more</span>
          </p>
          <a href="/blog" class="btn btn-secondary">Read More Articles</a>
        </div>
      </div>
    </div>
  </article>
</MainLayout>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .blog-post {
    margin-bottom: 4rem;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba($cta-primary, 0.2);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: $text-body;
    font-size: 0.95rem;
    margin-bottom: 2rem;
    transition: color 0.3s ease;

    &:hover {
      color: $cta-primary;
    }
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .category-tag {
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    background-color: rgba($cta-primary, 0.2);
    color: $cta-primary;
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .post-date,
  .read-time {
    font-family: "Courier New", monospace;
    font-size: 0.875rem;
    color: rgba($text-body, 0.7);
  }

  .post-title {
    font-size: 2rem;
    line-height: 1.2;
    margin-bottom: 1rem;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;

    @include tablet {
      font-size: 2.5rem;
    }
  }

  .prompt {
    color: $cta-primary;
    font-weight: 600;
    flex-shrink: 0;
  }

  .post-description {
    font-size: 1.125rem;
    color: $text-body;
    line-height: 1.6;
  }

  .post-content {
    margin-bottom: 3rem;
  }

  .content-wrapper {
    max-width: 720px;

    :global(h2) {
      color: $text-heading;
      font-size: 1.75rem;
      margin: 2rem 0 1rem;
      padding-top: 1rem;
    }

    :global(h3) {
      color: $text-heading;
      font-size: 1.375rem;
      margin: 1.5rem 0 0.75rem;
    }

    :global(p) {
      color: $text-body;
      line-height: 1.7;
      margin-bottom: 1.25rem;
      font-size: 1.05rem;
    }

    :global(ul),
    :global(ol) {
      color: $text-body;
      line-height: 1.7;
      margin-bottom: 1.25rem;
      padding-left: 1.5rem;

      :global(li) {
        margin-bottom: 0.5rem;
      }
    }

    :global(pre) {
      background-color: $bg-code;
      border: 1px solid rgba($cta-primary, 0.2);
      border-radius: 4px;
      padding: 1.5rem;
      overflow-x: auto;
      margin-bottom: 1.5rem;

      :global(code) {
        font-family: "Courier New", monospace;
        font-size: 0.9rem;
        color: $text-body;
        line-height: 1.6;
      }
    }

    :global(code) {
      font-family: "Courier New", monospace;
      font-size: 0.9em;
      background-color: rgba($bg-code, 0.5);
      padding: 0.2em 0.4em;
      border-radius: 2px;
      color: $cta-hover;
    }

    :global(pre code) {
      background-color: transparent;
      padding: 0;
    }

    :global(a) {
      color: $cta-primary;
      text-decoration: underline;

      &:hover {
        color: $cta-hover;
      }
    }
  }

  .post-footer {
    margin-top: 4rem;
  }

  .terminal-box {
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    padding: 2rem 1.5rem;
    border-radius: 4px;
    text-align: center;

    @include tablet {
      padding: 3rem 2rem;
    }
  }

  .terminal-text {
    font-family: "Courier New", monospace;
    color: $text-body;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .command {
    color: $cta-hover;
    margin-left: 0.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    border-radius: 4px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 1rem;
    min-height: 44px;
  }

  .btn-secondary {
    background-color: transparent;
    color: $text-heading;
    border-color: rgba($cta-primary, 0.4);

    &:hover {
      border-color: $cta-primary;
      background-color: rgba($cta-primary, 0.1);
    }
  }
</style>
