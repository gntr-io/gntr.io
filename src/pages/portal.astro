---
import MainLayout from "../layouts/MainLayout.astro";
import Portal from "../components/Portal";
---

<MainLayout title="Portal - gntr">
  <section class="portal-page">
    <div class="container">
      <Portal client:only="react" />
    </div>
  </section>
</MainLayout>

<style lang="scss">
  @use "../styles/variables" as *;

  .portal-page {
    min-height: calc(100vh - 280px);
    display: flex;
    align-items: center;
  }
</style>

<style is:global lang="scss">
  @use "../styles/variables" as *;

  .portal-status,
  .portal-app {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    border-radius: 8px;
    max-width: 480px;
  }

  .portal-line {
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.95rem;
    color: $text-body;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .portal-dim {
    color: rgba($text-body, 0.4);
    font-size: 0.85rem;
  }

  .portal-prompt {
    color: $cta-primary;
    font-weight: 600;
  }

  .portal-command {
    color: $cta-hover;
  }

  .portal-error-text {
    color: $cta-primary;
  }

  .portal-cursor {
    color: $cta-hover;
    animation: blink 1s step-end infinite;
  }

  .portal-support {
    color: $cta-primary;
    text-decoration: underline;

    &:hover {
      color: $cta-hover;
    }
  }

  .portal-back {
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.875rem;
    color: $cta-hover;
    text-decoration: none;

    &:hover {
      text-decoration: underline;
    }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
