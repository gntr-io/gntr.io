---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Login - gntr"
  description="Client portal login"
>
  <section class="login-page">
    <div class="container">
      <div class="login-card">
        <div class="card-header">
          <h1 class="page-title">
            <span class="prompt">›</span> Client Portal
          </h1>
          <p class="page-description">Sign in to access your workspace.</p>
        </div>

        <form class="login-form" id="loginForm" method="post" action="" novalidate>
          <div class="form-group">
            <label for="email" class="form-label">
              <span class="prompt">›</span> Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="you@example.com"
              autocomplete="email"
              required
            />
          </div>

          <div class="form-group">
            <label for="password" class="form-label">
              <span class="prompt">›</span> Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              class="form-input"
              placeholder="••••••••"
              autocomplete="current-password"
              required
            />
          </div>

          <p class="form-error" id="loginError" aria-live="polite"></p>

          <button type="submit" class="btn btn-primary btn-block" id="loginBtn">
            Sign In
          </button>
        </form>

        <div class="terminal-footer">
          <span class="prompt">›</span>
          <span class="terminal-text">gntr.io -- authenticated access only</span>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style lang="scss">
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .login-page {
    display: flex;
    align-items: center;
    min-height: calc(100vh - 280px);
  }

  .container {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .login-card {
    width: 100%;
    max-width: 440px;
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    border-radius: 8px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .page-title {
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
  }

  .prompt {
    color: $cta-primary;
    font-weight: 600;
  }

  .page-description {
    color: $text-body;
    font-size: 0.95rem;
    margin: 0;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: $text-heading;
    font-size: 0.95rem;
  }

  .form-input {
    width: 100%;
    background-color: rgba($bg-primary, 0.5);
    border: 1px solid rgba($cta-primary, 0.2);
    color: $text-body;
    padding: 0.75rem;
    border-radius: 8px;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    box-sizing: border-box;

    &:focus {
      outline: none;
      border-color: $cta-primary;
      background-color: rgba($bg-primary, 0.7);
    }

    &::placeholder {
      color: rgba($text-body, 0.4);
    }
  }

  .form-error {
    color: $cta-primary;
    font-size: 0.875rem;
    font-family: "JetBrains Mono", "Courier New", monospace;
    min-height: 1.25rem;
    margin: 0;

    &:not(:empty)::before {
      content: "✗ ";
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 1px solid transparent;
    font-size: 1rem;
    min-height: 44px;
  }

  .btn-primary {
    background-color: $cta-primary;
    color: $bg-primary;
    border-color: $cta-primary;

    &:hover:not(:disabled) {
      background-color: $cta-hover;
      border-color: $cta-hover;
      transform: translateY(-1px);
    }

    &:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
  }

  .btn-block {
    width: 100%;
  }

  .terminal-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba($cta-primary, 0.1);
  }

  .terminal-text {
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.8rem;
    color: rgba($text-body, 0.4);
  }
</style>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.getElementById("loginForm") as HTMLFormElement;
  const errorEl = document.getElementById("loginError") as HTMLParagraphElement;
  const btn = document.getElementById("loginBtn") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.textContent = "";
    btn.disabled = true;
    btn.textContent = "Signing in…";

    const email = (document.getElementById("email") as HTMLInputElement).value;
    const password = (document.getElementById("password") as HTMLInputElement).value;

    const { error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      errorEl.textContent = error.message;
      btn.disabled = false;
      btn.textContent = "Sign In";
    } else {
      window.location.href = "/portal";
    }
  });
</script>
