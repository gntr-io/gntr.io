---
import MainLayout from "../layouts/MainLayout.astro";

const projects = [
  {
    title: "Advertising Intelligence Platform",
    description:
      "A SaaS product that connects to live ad account data, applies expert media-buyer analysis frameworks, and surfaces specific recommendations — not generic advice. Built with multi-client data isolation from day one.",
    tech: ["Python", "Claude API", "MCP", "PostgreSQL", "GCP"],
    status: "live",
    year: "2025",
  },
  {
    title: "Automated Performance Data Pipeline",
    description:
      "A data pipeline that pulls advertising performance data from third-party APIs every 12 hours, reconciles attribution lag across tiered lookback windows, and feeds a structured warehouse of 20+ tables for AI-driven analysis.",
    tech: ["Python", "Google Ads API", "Cloud Run", "PostgreSQL"],
    status: "live",
    year: "2025",
  },
  {
    title: "Expertise Encoding System",
    description:
      "An AI layer that encodes a specialist's decision-making framework into structured prompts — so the system reasons like an expert, not a generalist. Applied across three funnel stages with specific, actionable outputs.",
    tech: ["Claude API", "MCP", "TypeScript", "FastAPI"],
    status: "live",
    year: "2025",
  },
];
---

<MainLayout
  title="Portfolio - gntr"
  description="Real projects built by gntr — AI systems, data pipelines, and productised expertise for businesses that have outgrown generic software."
>
  <section class="portfolio">
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">
          <span class="prompt">›</span> Portfolio
        </h1>
        <p class="page-description">
          Real projects. Real businesses. AI systems, data pipelines, and productised expertise built for companies that have outgrown generic software.
        </p>
      </div>

      <div class="projects-grid">
        {
          projects.map((project) => (
            <article class="project-card">
              <div class="project-header">
                <div class="project-meta">
                  <code class="status-badge status-{project.status}">
                    {project.status}
                  </code>
                  <span class="project-year">{project.year}</span>
                </div>
              </div>
              <h2 class="project-title">
                <span class="prompt">{'>'}</span> {project.title}
              </h2>
              <p class="project-description">{project.description}</p>
              <div class="tech-stack">
                <span class="tech-label">Stack:</span>
                <div class="tech-tags">
                  {project.tech.map((tech) => (
                    <span class="tech-tag">{tech}</span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="cta-section">
        <div class="terminal-box">
          <p class="terminal-text">
            <span class="prompt">›</span>
            <span class="command">gntr create --project=yours</span>
          </p>
          <p class="cta-text">Ready to start your project?</p>
          <a href="/contact" class="btn btn-primary">Get In Touch</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style lang="scss">
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .portfolio {
    margin-bottom: 4rem;
  }

  .page-header {
    margin-bottom: 3rem;

    @include tablet {
      margin-bottom: 4rem;
    }
  }

  .page-title {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;

    @include tablet {
      font-size: 2.5rem;
    }
  }

  .prompt {
    color: $cta-primary;
    font-weight: 600;
  }

  .page-description {
    font-size: 1.125rem;
    color: $text-body;
    max-width: 600px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 4rem;

    @include tablet {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  .project-card {
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    padding: 1.5rem;
    border-radius: 4px;
    transition: all 0.3s ease;

    &:hover {
      border-color: $cta-primary;
      transform: translateY(-2px);
    }
  }

  .project-header {
    margin-bottom: 1rem;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .status-badge {
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .status-completed,
  .status-live {
    background-color: rgba($cta-primary, 0.2);
    color: $cta-primary;
  }

  .project-year {
    font-family: "Courier New", monospace;
    font-size: 0.875rem;
    color: rgba($text-body, 0.7);
  }

  .project-title {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: $text-heading;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .project-description {
    color: $text-body;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .tech-stack {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tech-label {
    font-family: "Courier New", monospace;
    font-size: 0.875rem;
    color: $cta-hover;
    font-weight: 600;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-tag {
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    background-color: rgba($bg-code, 0.5);
    color: $text-body;
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    border: 1px solid rgba($cta-primary, 0.1);
  }

  .cta-section {
    margin-top: 4rem;
  }

  .terminal-box {
    background-color: $bg-card;
    border: 1px solid rgba($cta-primary, 0.2);
    padding: 2rem 1.5rem;
    border-radius: 4px;
    text-align: center;

    @include tablet {
      padding: 3rem 2rem;
    }
  }

  .terminal-text {
    font-family: "Courier New", monospace;
    color: $text-body;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .command {
    color: $cta-hover;
    margin-left: 0.5rem;
  }

  .cta-text {
    font-size: 1.25rem;
    color: $text-heading;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    border-radius: 4px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 1rem;
    min-height: 44px;
  }

  .btn-primary {
    background-color: $cta-primary;
    color: $bg-primary;
    border-color: $cta-primary;

    &:hover {
      background-color: $cta-hover;
      border-color: $cta-hover;
      transform: translateY(-1px);
    }
  }
</style>
